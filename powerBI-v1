    def export_excel(self):
        desktop = os.path.join(os.path.expanduser("~"), "Desktop")
        filename = os.path.join(desktop, f"Server_NPI_Export_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.csv")
        ld = self.lang_dict[self.current_lang]
        try:
            with open(filename, mode='w', newline='', encoding='utf-8-sig') as f:
                writer = csv.writer(f, delimiter=';')
                writer.writerow([ld["t_ser"], ld["t_mod"], ld["t_tst"], ld["t_res"], ld["t_dt"], ld["t_usr"]])
                for r in self.records: writer.writerow(r[1:])
            messagebox.showinfo("Excel", "Exportado en Escritorio.")
        except Exception as e:
            messagebox.showerror("Error", str(e))

    def export_pdf(self):
        desktop = os.path.join(os.path.expanduser("~"), "Desktop")
        filename = os.path.join(desktop, f"NPI_Server_Report_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf")
        ld = self.lang_dict[self.current_lang]
        
        doc = SimpleDocTemplate(filename, pagesize=letter, rightMargin=30, leftMargin=30, topMargin=30, bottomMargin=30)
        story = []
        styles = getSampleStyleSheet()
        
        t_style = ParagraphStyle('T', parent=styles['Heading1'], fontName='Helvetica-Bold', fontSize=18, textColor=colors.HexColor('#0071E3'))
        c_style = ParagraphStyle('C', parent=styles['Normal'], fontName='Helvetica', fontSize=8, leading=10)
        
        story.append(Paragraph(ld["title"], t_style))
        story.append(Spacer(1, 15))
        
        table_data = [[Paragraph(f"<b>{h}</b>", c_style) for h in [ld["t_ser"], ld["t_mod"], ld["t_tst"], ld["t_res"], ld["t_dt"]]]]
        for row in self.records:
            table_data.append([Paragraph(str(item), c_style) for item in row[1:6]])
            
        pdf_table = Table(table_data, colWidths=[100, 90, 100, 60, 120])
        ts = TableStyle([
            ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#F5F5F7')),
            ('GRID', (0,0), (-1,-1), 0.5, colors.HexColor('#E5E5EA')),
            ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
        ])
        
        for i, r in enumerate(self.records, start=1):
            bg = colors.HexColor('#E8F5E9') if r[4] == "Pass" else colors.HexColor('#FFEBEE')
            ts.add('BACKGROUND', (0, i), (-1, i), bg)
            
        pdf_table.setStyle(ts)
        story.append(pdf_table)
        doc.build(story)
        messagebox.showinfo("PDF", "Reporte PDF guardado en Escritorio.")

