    def init_database(self):
        self.conn = sqlite3.connect("npi_automated_quality.db")
        self.cursor = self.conn.cursor()
        self.cursor.execute("""
            CREATE TABLE IF NOT EXISTS server_logs (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                serial TEXT NOT NULL,
                model TEXT NOT NULL,
                test TEXT NOT NULL,
                result TEXT NOT NULL,
                datetime TEXT NOT NULL,
                user TEXT NOT NULL,
                UNIQUE(serial, datetime)
            )
        """)
        self.conn.commit()

    def load_data(self, query=""):
        for item in self.tree.get_children():
            self.tree.delete(item)
            
        if query:
            search_filter = f"%{query}%"
            self.cursor.execute("""
                SELECT id, serial, model, test, result, datetime, user 
                FROM server_logs 
                WHERE serial LIKE ? OR model LIKE ? OR test LIKE ? 
                ORDER BY datetime DESC
            """, (search_filter, search_filter, search_filter))
        else:
            self.cursor.execute("SELECT id, serial, model, test, result, datetime, user FROM server_logs ORDER BY datetime DESC")
            
        self.records = self.cursor.fetchall()
        
        theme_name = "dark" if self.dark_mode else "light"
        self.tree.tag_configure("pass_row", background=self.themes[theme_name]["pass_bg"])
        self.tree.tag_configure("fail_row", background=self.themes[theme_name]["fail_bg"])
        
        for row in self.records:
            tag = "pass_row" if row[4] == "Pass" else "fail_row"
            self.tree.insert("", "end", iid=str(row[0]), values=row[1:], tags=(tag,))
            
        self.lbl_status.config(text=self.lang_dict[self.current_lang]["status_total"].format(len(self.records)))
        self.update_dashboard()

    def update_dashboard(self):
        if self.canvas_plot:
            self.canvas_plot.get_tk_widget().destroy()
            
        pass_count = sum(1 for row in self.records if row[4] == "Pass")
        fail_count = sum(1 for row in self.records if row[4] == "Fail")
        theme = self.themes["dark" if self.dark_mode else "light"]
        
        fig = Figure(figsize=(6, 1.8), dpi=100, facecolor=theme["card"])
        ax = fig.add_subplot(111, facecolor=theme["card"])
        
        categories = ['Pass', 'Fail'] if self.current_lang == "ENG" else ['Aprobados', 'Fallidos']
        counts = [pass_count, fail_count]
        
        bars = ax.barh(categories, counts, color=['#34C759', '#FF3B30'], height=0.5)
        for spine in ['top', 'right']: ax.spines[spine].set_visible(False)
        ax.spines['left'].set_color(theme["text_sub"])
        ax.spines['bottom'].set_color(theme["text_sub"])
        ax.tick_params(colors=theme["text"], labelsize=9)
        ax.xaxis.get_major_locator().set_params(integer=True)
        
        for bar in bars:
            width = bar.get_width()
            ax.text(width + 0.1, bar.get_y() + bar.get_height()/2, f'{int(width)}', 
                    va='center', ha='left', color=theme["text"], fontsize=9, fontweight='bold')
                    
        fig.tight_layout()
        self.canvas_plot = FigureCanvasTkAgg(fig, master=self.chart_frame)
        self.canvas_plot.draw()
        self.canvas_plot.get_tk_widget().pack(fill="both", expand=True)

    def scan_server_logs(self):
        start_str = self.e_start.get().strip()
        end_str = self.e_end.get().strip()
        
        try:
            start_date = datetime.datetime.strptime(start_str, "%Y-%m-%d").date()
            end_date = datetime.datetime.strptime(end_str, "%Y-%m-%d").date()
        except ValueError:
            messagebox.showerror("Error", "Format: YYYY-MM-DD")
            return
            
        if not os.path.exists(self.log_directory):
            messagebox.showerror("Error", f"Path not found: {self.log_directory}")
            return
            
        all_files = glob.glob(os.path.join(self.log_directory, "*.txt")) + glob.glob(os.path.join(self.log_directory, "*.log"))
        imported_count = 0
        
        for file_path in all_files:
            try:
                mtime = os.path.getmtime(file_path)
                file_date = datetime.datetime.fromtimestamp(mtime).date()
            except Exception:
                continue
                
            if start_date <= file_date <= end_date:
                serial, model, test, result, dt = LogParserEngine.parse_file(file_path)
                if serial and dt:
                    try:
                        operator = getpass.getuser()
                        self.cursor.execute("""
                            INSERT INTO server_logs (serial, model, test, result, datetime, user)
                            VALUES (?, ?, ?, ?, ?, ?)
                        """, (serial, model, test, result, dt, operator))
                        imported_count += 1
                    except sqlite3.IntegrityError:
                        pass  # Evita duplicados automáticos mediante el constraint UNIQUE
                        
        self.conn.commit()
        self.load_data()
        messagebox.showinfo("Scanner", f"Escaneo Completo. {imported_count} nuevos registros añadidos.")

    def delete_item(self):
        selected = self.tree.selection()
        if not selected: return
        self.cursor.execute("DELETE FROM server_logs WHERE id = ?", (selected[0],))
        self.conn.commit()
        self.load_data()

    def clear_database(self):
        if messagebox.askyesno(self.lang_dict[self.current_lang]["clear_title"], self.lang_dict[self.current_lang]["clear_msg"]):
            self.cursor.execute("DELETE FROM server_logs")
            self.conn.commit()
            self.load_data()

