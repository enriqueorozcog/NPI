class LogParserEngine:
    """Clase encargada de leer, estructurar y validar los logs de los servidores."""
    @staticmethod
    def parse_file(file_path):
        serial, model, test, result, dt = None, None, None, "Fail", None
        
        # Regex optimizadas para capturar marcas de tiempo e inyecciones JSON
        timestamp_regex = re.compile(r"^\[(?P<dt>\d{4}-\d{2}-\d{2})T(?P<time>\d{2}:\d{2}:\d{2})")
        json_regex = re.compile(r"-\s+(\{.*ProductName.*SerialNumber.*\})")
        
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                
                # Reseteamos puntero para lectura línea por línea rápido
                f.seek(0)
                for line in f:
                    # Capturar la primera estampa de tiempo válida para el registro
                    if not dt:
                        ts_match = timestamp_regex.match(line)
                        if ts_match:
                            dt = f"{ts_match.group('dt')} {ts_match.group('time')}"
                    
                    # Detectar el tipo de prueba en ejecución
                    if "Starting CrewReprovision..." in line:
                        test = "Provision"
                    elif "Starting CrewDevicePrep..." in line:
                        test = "DevicePrep"
                    
                    # Extraer JSON de configuración de la unidad
                    json_match = json_regex.search(line)
                    if json_match:
                        try:
                            raw_json = json_match.group(1)
                            data = json.loads(raw_json)
                            serial = data.get("SerialNumber") or data.get("SystemDutSn")
                            model = data.get("ProductName") or data.get("Project")
                        except Exception:
                            pass

            # Lógica PowerShell replicada de forma exacta
            if "Crew-DevicePrep Success" in content or "Crew-Reprovision Success" in content:
                result = "Pass"
            else:
                result = "Fail"
                
        except Exception as e:
            print(f"Error procesando archivo {file_path}: {e}")
            
        return serial, model, test, result, dt
