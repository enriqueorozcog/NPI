        tx = self.lang_dict[self.current_lang]
        if self.e_search.get() == tx["search_placeholder"]:
            self.e_search.delete(0, tk.END)
            self.e_search.config(fg=self.themes["dark" if self.dark_mode else "light"]["text"])

    def restore_placeholder(self):
        tx = self.lang_dict[self.current_lang]
        if not self.e_search.get().strip():
            self.e_search.insert(0, tx["search_placeholder"])
            self.e_search.config(fg=self.themes["dark" if self.dark_mode else "light"]["text_sub"])
    def toggle_theme(self):
