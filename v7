    def validate_alphanumeric(self, current_text):
        if current_text == "":
            return True
        return current_text.isalnum()


    def init_database(self):
        self.conn = sqlite3.connect("npi_system.db")
        self.cursor = self.conn.cursor()
        self.cursor.execute("""
            CREATE TABLE IF NOT EXISTS validations (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                serial TEXT,
                model TEXT,
                test TEXT,
                result TEXT,
                comments TEXT,
                date_time TEXT,
                operator TEXT
            )
        """)
        self.conn.commit()

    def update_model_suggestions(self):
        """Carga y actualiza de manera dinámica el historial de modelos en el Combobox"""
        self.cursor.execute("SELECT DISTINCT model FROM validations WHERE model != '' ORDER BY model ASC")
        models = [r[0] for r in self.cursor.fetchall()]
        self.c_mod['values'] = models

    def update_dashboard(self):
        """Dibuja e integra el gráfico estadístico Pass/Fail en tiempo real dentro de la app"""
        if self.canvas_plot:
            self.canvas_plot.get_tk_widget().destroy()
            self.canvas_plot = None

        passes = sum(1 for r in self.records if r[3] == "Pass")
        fails = sum(1 for r in self.records if r[3] == "Fail")
        total = len(self.records)

        t = self.themes["dark" if self.dark_mode else "light"]
        
        fig = Figure(figsize=(4, 1.6), dpi=100)
        fig.patch.set_facecolor(t["bg"])
        ax = fig.add_subplot(111)
        ax.set_facecolor(t["bg"])

        if total == 0:
            ax.pie([1], colors=[t["border"]], radius=1.2, wedgeprops=dict(width=0.4, edgecolor=t["bg"]))
            ax.text(0, 0, "No Data", ha='center', va='center', color=t["text_sub"], fontname="sans-serif", fontsize=10, weight='bold')
        else:
            sizes = [passes, fails]
            colors_pie = ["#34C759", "#FF3B30"]
            
            wedges, texts = ax.pie(
                sizes, 
                colors=colors_pie, 
                radius=1.2, 
                wedgeprops=dict(width=0.35, edgecolor=t["card"], linewidth=1.5),
                startangle=90
            )
            
            ax.text(0, 0, f"Total\n{total}", ha='center', va='center', color=t["text"], fontname="sans-serif", fontsize=9, weight='bold')
            
            tx = self.lang_dict[self.current_lang]
            ax.legend(
                labels=[f"Pass: {passes}", f"Fail: {fails}"],
                loc="center right",
                bbox_to_anchor=(1.7, 0.5),
                frameon=False,
                prop={'family': 'sans-serif', 'size': 8, 'weight': 'bold'},
                labelcolor=t["text"]
            )

        ax.axis('tight')
        self.canvas_plot = FigureCanvasTkAgg(fig, master=self.dashboard_frame)
        self.canvas_plot.draw()
        self.canvas_plot.get_tk_widget().pack(expand=True, fill="both")

    def load_stored_data(self):
        for item in self.tabla.get_children():
            self.tabla.delete(item)
        self.records = []
        
        self.cursor.execute("SELECT id, serial, model, test, result, comments, date_time, operator FROM validations ORDER BY id DESC")
        rows = self.cursor.fetchall()
        for r in rows:
            self.tabla.insert("", "end", values=r)
            self.records.append(list(r[1:]))
            
        self.update_status_count()
        self.update_model_suggestions()
        self.update_dashboard()
        self.apply_row_colors()


    def update_status_count(self):
        tx = self.lang_dict[self.current_lang]
        self.lbl_status.config(text=tx["status_total"].format(len(self.records)))

    def apply_row_colors(self):
        """Aplica colores sutiles estilo semáforo a las filas según el resultado"""
        t = self.themes["dark" if self.dark_mode else "light"]
        self.tabla.tag_configure("pass_row", background=t["pass_bg"])
        self.tabla.tag_configure("fail_row", background=t["fail_bg"])
        
        for item in self.tabla.get_children():
            values = self.tabla.item(item, "values")
            resultado = values[4]  # Índice 4 corresponde a la columna Result
            if resultado == "Pass":
                self.tabla.item(item, tags=("pass_row",))
            elif resultado == "Fail":
                self.tabla.item(item, tags=("fail_row",))

    def clear_entire_database(self):
        tx = self.lang_dict[self.current_lang]
        confirmacion = messagebox.askyesno(tx["clear_title"], tx["clear_msg"], icon="warning")
        if confirmacion:
            self.cursor.execute("DELETE FROM validations")
            self.conn.commit()
            self.load_stored_data()

    def filter_data(self, *args):
        query = self.search_var.get().strip().lower()
        tx = self.lang_dict[self.current_lang]
        if query == tx["search_placeholder"].lower():
            return
            
        for item in self.tabla.get_children():
            self.tabla.delete(item)
            
        if not query:
            self.load_stored_data()
            return
            
        self.cursor.execute("""
            SELECT id, serial, model, test, result, comments, date_time, operator FROM validations 
            WHERE LOWER(serial) LIKE ? OR LOWER(model) LIKE ? OR LOWER(operator) LIKE ?
        """, (f'%{query}%', f'%{query}%', f'%{query}%'))
        
        rows = self.cursor.fetchall()
        self.records = []
        for r in rows:
            self.tabla.insert("", "end", values=r)
            self.records.append(list(r[1:]))
            
        self.update_status_count()
        self.update_dashboard()
        self.apply_row_colors()

