    def get_status_value(self):
        ld = self.lang_dict[self.current_lang]
        selected = self.status_filter.get()

        if selected == ld["all"]:
            return "All"
        if selected == ld["pass"]:
            return "Pass"
        if selected == ld["fail"]:
            return "Fail"
        return "All"

    def load_data(self, query=None, status=None):
        if query is None:
            query = self.search_var.get() if hasattr(self, "search_var") else ""

        if status is None:
            status = self.get_status_value() if hasattr(self, "status_filter") else "All"

        for item in self.tree.get_children():
            self.tree.delete(item)

        try:
            start_str = self.e_start.get_date().strftime("%Y-%m-%d")
            end_str = self.e_end.get_date().strftime("%Y-%m-%d")
        except Exception:
            start_str = "2000-01-01"
            end_str = "2099-12-31"

        sql_query = """
            SELECT id, serial, model, test, result, datetime, user
            FROM server_logs
            WHERE date(datetime) >= date(?) AND date(datetime) <= date(?)
        """
        params = [start_str, end_str]

        if query:
            sql_query += " AND (serial LIKE ? OR model LIKE ?)"
            sf = f"%{query}%"
            params.extend([sf, sf])

        if status and status != "All":
            sql_query += " AND result = ?"
            params.append(status)

        sql_query += " ORDER BY datetime DESC"

        self.cursor.execute(sql_query, params)
        self.records = self.cursor.fetchall()

        theme_name = "dark" if self.dark_mode else "light"
        theme = self.themes[theme_name]

        self.tree.tag_configure(
            "pass_row",
            background=theme["pass_bg"],
            foreground=theme["text"]
        )
        self.tree.tag_configure(
            "fail_row",
            background=theme["fail_bg"],
            foreground=theme["text"]
        )

        pass_c = sum(1 for r in self.records if r[4] == "Pass")
        fail_c = sum(1 for r in self.records if r[4] == "Fail")
        total = len(self.records)
        yield_p = round((pass_c / total) * 100, 1) if total else 100.0

        for row in self.records:
            tag = "pass_row" if row[4] == "Pass" else "fail_row"
            self.tree.insert("", "end", iid=str(row[0]), values=row[1:], tags=(tag,))

        self.update_kpis(total, pass_c, fail_c, yield_p)
        self.update_dashboard(pass_c, fail_c)

    def update_kpis(self, total, pass_c, fail_c, yield_p):
        ld = self.lang_dict[self.current_lang]

        self.kpi_cards["records"]["label"].config(text=ld["kpi_records"])
        self.kpi_cards["records"]["value"].config(text=str(total))
        self.kpi_cards["records"]["hint"].config(text="Filtered dataset")

        self.kpi_cards["yield"]["label"].config(text=ld["kpi_yield"])
        self.kpi_cards["yield"]["value"].config(text=f"{yield_p}%")
        self.kpi_cards["yield"]["hint"].config(text="Pass / Total")

        self.kpi_cards["pass"]["label"].config(text=ld["kpi_pass"])
        self.kpi_cards["pass"]["value"].config(text=str(pass_c))
        self.kpi_cards["pass"]["hint"].config(text="Successful logs")

        self.kpi_cards["fail"]["label"].config(text=ld["kpi_fail"])
        self.kpi_cards["fail"]["value"].config(text=str(fail_c))
        self.kpi_cards["fail"]["hint"].config(text="Failed logs")

    def update_dashboard(self, pass_c, fail_c):
        theme = self.themes["dark" if self.dark_mode else "light"]
        ld = self.lang_dict[self.current_lang]

        self.ax.clear()
        self.fig.set_facecolor(theme["card"])
        self.ax.set_facecolor(theme["card"])

        cats = [ld["pass"], ld["fail"]]
        values = [pass_c, fail_c]
        colors_bar = [theme["success"], theme["danger"]]

        bars = self.ax.barh(cats, values, color=colors_bar, height=0.45)

        for spine in ["top", "right", "left"]:
            self.ax.spines[spine].set_visible(False)

        self.ax.spines["bottom"].set_color(theme["border"])
        self.ax.tick_params(colors=theme["text_muted"], labelsize=9)
        self.ax.grid(axis="x", color=theme["border"], linewidth=0.7, alpha=0.45)
        self.ax.set_axisbelow(True)

        max_value = max(values) if values else 0
        self.ax.set_xlim(0, max_value + max(5, max_value * 0.12))

        for bar in bars:
            width = bar.get_width()
            self.ax.text(
                width + 0.2,
                bar.get_y() + bar.get_height() / 2,
                f"{int(width)}",
                va="center",
                ha="left",
                color=theme["text"],
                fontsize=9,
                fontweight="bold"
            )

        self.fig.tight_layout(pad=1.0)
        self.canvas_plot.draw()

    # ==========================================================
    # SCAN
    # ==========================================================
    def start_async_scan(self):
        self.btn_scan.config(state="disabled")
        threading.Thread(target=self.scan_server_logs, args=(True,), daemon=True).start()

    def scan_server_logs(self, show_alert=False):
        try:
            start_d = self.e_start.get_date()
            end_d = self.e_end.get_date()
        except Exception:
            if show_alert:
                self.root.after(0, lambda: messagebox.showerror("Error", "Error al leer calendarios."))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return

        if not os.path.exists(self.log_directory):
            if show_alert:
                self.root.after(0, lambda: messagebox.showerror("Error", f"Ruta vacía: {self.log_directory}"))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return

        files = glob.glob(os.path.join(self.log_directory, "**", "*.txt"), recursive=True)
        files += glob.glob(os.path.join(self.log_directory, "**", "*.log"), recursive=True)

        valid_files = []
        for f in files:
            try:
                f_date = datetime.datetime.fromtimestamp(os.path.getmtime(f)).date()
                if start_d <= f_date <= end_d:
                    valid_files.append(f)
            except Exception:
                continue

        total = len(valid_files)
        if total == 0:
            if show_alert:
                self.root.after(0, lambda: messagebox.showinfo("Scanner", "0 logs hallados."))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return

        imported = 0
        local_conn = sqlite3.connect("npi_automated_quality.db")
        local_cursor = local_conn.cursor()

        for i, f_path in enumerate(valid_files):
            serial, model, test, result, dt = LogParserEngine.parse_file(f_path)

            if serial and dt:
                try:
                    local_cursor.execute("""
                        INSERT INTO server_logs
                        (serial, model, test, result, datetime, user)
                        VALUES (?, ?, ?, ?, ?, ?)
                    """, (serial, model, test, result, dt, getpass.getuser()))
                    imported += 1
                except sqlite3.IntegrityError:
                    pass

            progress_value = int(((i + 1) / total) * 100)
            self.root.after(0, lambda p=progress_value: self.progress.configure(value=p))

        local_conn.commit()
        local_cursor.close()
        local_conn.close()

        self.root.after(0, lambda: self.load_data())
        self.root.after(0, lambda: self.progress.configure(value=0))
        self.root.after(0, lambda: self.btn_scan.config(state="normal"))

        if show_alert and imported > 0:
            self.root.after(0, lambda: messagebox.showinfo("Scanner", f"Listo. Añadidos: {imported}"))

    # ==========================================================
    # LIVE MODE
    # ==========================================================
    def toggle_live_mode(self):
        self.live_mode = not self.live_mode
        self.update_ui_text()
        self.apply_theme()

    def run_live_loop(self):
        if self.live_mode:
            threading.Thread(target=self.scan_server_logs, args=(False,), daemon=True).start()
        self.root.after(5000, self.run_live_loop)

    # ==========================================================
    # ACTIONS
    # ==========================================================
    def delete_item(self):
        sel = self.tree.selection()
        if not sel:
            return

        self.cursor.execute("DELETE FROM server_logs WHERE id = ?", (sel[0],))
        self.conn.commit()
        self.load_data()

    def clear_database(self):
        ld = self.lang_dict[self.current_lang]
        if messagebox.askyesno(ld["clear_title"], ld["clear_msg"]):
            self.cursor.execute("DELETE FROM server_logs")
            self.conn.commit()
            self.load_data()

    def open_log_viewer(self, event):
        sel = self.tree.selection()
        if not sel:
            return

        item_values = self.tree.item(sel, "values")
        if not item_values:
            return

        serial_sel = str(item_values[0]).strip().upper()

        files = glob.glob(os.path.join(self.log_directory, "**", f"*{serial_sel}*.*"), recursive=True)

        if not files:
            all_text_files = glob.glob(os.path.join(self.log_directory, "**", "*.txt"), recursive=True)
            all_text_files += glob.glob(os.path.join(self.log_directory, "**", "*.log"), recursive=True)
            for f in all_text_files:
                try:
                    if serial_sel in f.upper():
                        files.append(f)
                        break
                except Exception:
                    continue

        target_file = files[0] if files else None

        if not target_file or not os.path.exists(target_file):
            messagebox.showwarning("Visor Logs", f"No se encontró archivo para: {serial_sel}")
            return

        theme = self.themes["dark" if self.dark_mode else "light"]

        win = tk.Toplevel(self.root)
        win.title(f"Log Viewer - Serial: {serial_sel}")
        win.geometry("820x560")
        win.config(bg=theme["app_bg"])

        header = tk.Frame(win, bg=theme["app_bg"])
        header.pack(fill="x", padx=18, pady=(16, 8))

        tk.Label(
            header,
            text=f"Log Viewer · {serial_sel}",
            bg=theme["app_bg"],
            fg=theme["text"],
            font=("Segoe UI", 14, "bold")
        ).pack(anchor="w")

        txt_frame = tk.Frame(
            win,
            bg=theme["card"],
            highlightbackground=theme["border"],
            highlightthickness=1
        )
        txt_frame.pack(fill="both", expand=True, padx=18, pady=(0, 18))

        scr = tk.Scrollbar(txt_frame)
        scr.pack(side="right", fill="y")

        box = tk.Text(
            txt_frame,
            wrap="word",
            yscrollcommand=scr.set,
            font=("Consolas", 10),
            bd=0,
            bg=theme["card"],
            fg=theme["text"],
            insertbackground=theme["text"],
            padx=12,
            pady=12
        )
        box.pack(side="left", fill="both", expand=True)
        scr.config(command=box.yview)

        try:
            with open(target_file, "r", encoding="utf-8", errors="ignore") as fd:
                box.insert("1.0", fd.read())
        except Exception as e:
            box.insert("1.0", f"Error: {e}")

        box.config(state="disabled")

    # ==========================================================
    # EXPORTS
    # ==========================================================
    def export_excel(self):
        desktop = os.path.join(os.path.expanduser("~"), "Desktop")
        filename = os.path.join(
            desktop,
            f"Server_NPI_Export_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        )

        ld = self.lang_dict[self.current_lang]

        try:
            with open(filename, mode="w", newline="", encoding="utf-8-sig") as f:
                writer = csv.writer(f, delimiter=";")
                writer.writerow([ld["t_ser"], ld["t_mod"], ld["t_tst"], ld["t_res"], ld["t_dt"], ld["t_usr"]])
                for r in self.records:
                    writer.writerow(r[1:])

            messagebox.showinfo("CSV", "Archivo exportado en Escritorio.")
        except Exception as e:
            messagebox.showerror("Error", str(e))

    def export_pdf(self):
        desktop = os.path.join(os.path.expanduser("~"), "Desktop")
        filename = os.path.join(
            desktop,
            f"NPI_Server_Report_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf"
        )

        ld = self.lang_dict[self.current_lang]

        doc = SimpleDocTemplate(
            filename,
            pagesize=letter,
            rightMargin=30,
            leftMargin=30,
            topMargin=30,
            bottomMargin=30
        )

        story = []
        styles = getSampleStyleSheet()

        title_style = ParagraphStyle(
            "TitleModern",
            parent=styles["Heading1"],
            fontName="Helvetica-Bold",
            fontSize=18,
            textColor=colors.HexColor("#0078D4"),
            spaceAfter=12
        )

        cell_style = ParagraphStyle(
            "CellModern",
            parent=styles["Normal"],
            fontName="Helvetica",
            fontSize=8,
            leading=10
        )

        story.append(Paragraph(ld["title"], title_style))
        story.append(Spacer(1, 12))

        table_data = [[
            Paragraph(f"<b>{h}</b>", cell_style)
            for h in [ld["t_ser"], ld["t_mod"], ld["t_tst"], ld["t_res"], ld["t_dt"]]
        ]]

        for row in self.records:
            table_data.append([Paragraph(str(item), cell_style) for item in row[1:6]])

        pdf_table = Table(table_data, colWidths=[100, 90, 100, 70, 140])

        table_style = TableStyle([
            ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#F4F6FA")),
            ("TEXTCOLOR", (0, 0), (-1, 0), colors.HexColor("#1D1D1F")),
            ("GRID", (0, 0), (-1, -1), 0.35, colors.HexColor("#DCE1EA")),
            ("VALIGN", (0, 0), (-1, -1), "MIDDLE"),
            ("LEFTPADDING", (0, 0), (-1, -1), 6),
            ("RIGHTPADDING", (0, 0), (-1, -1), 6),
            ("TOPPADDING", (0, 0), (-1, -1), 5),
            ("BOTTOMPADDING", (0, 0), (-1, -1), 5),
        ])

        for i, r in enumerate(self.records, start=1):
            bg = colors.HexColor("#E7F6ED") if r[4] == "Pass" else colors.HexColor("#FDE7E9")
            table_style.add("BACKGROUND", (0, i), (-1, i), bg)

        pdf_table.setStyle(table_style)

        story.append(pdf_table)
        doc.build(story)

        messagebox.showinfo("PDF", "Reporte PDF guardado en Escritorio.")

    # ==========================================================
    # LANGUAGE / THEME
    # ==========================================================
    def toggle_lang(self):
        self.current_lang = "ESP" if self.current_lang == "ENG" else "ENG"
        self.update_ui_text()
        self.load_data()

    def toggle_theme(self):
        self.dark_mode = not self.dark_mode
        self.apply_theme()
        self.load_data()

    def update_ui_text(self):
        ld = self.lang_dict[self.current_lang]

        self.lbl_title.config(text=ld["title"])
        self.lbl_subtitle.config(text=ld["subtitle"])
        self.lbl_controls.config(text=ld["controls"])
        self.lbl_date_range.config(text=ld["date_range"])
        self.l_start.config(text=ld["start_date"])
        self.l_end.config(text=ld["end_date"])

        self.btn_scan.config(text=ld["b_scan"])
        self.btn_live.config(text=ld["b_live_on"] if self.live_mode else ld["b_live_off"])
        self.btn_clear_db.config(text=ld["b_clear_db"])
        self.btn_del.config(text=ld["b_del"])
        self.btn_excel.config(text=ld["b_excel"])
        self.btn_pdf.config(text=ld["b_pdf"])

        self.lbl_table_title.config(text=ld["table_title"])
        self.lbl_chart_title.config(text=ld["chart_title"])

        self.b_lang.config(text="ESP" if self.current_lang == "ENG" else "ENG")
        self.b_theme.config(text="☀" if self.dark_mode else "🌙")

        self.status_filter["values"] = (ld["all"], ld["pass"], ld["fail"])
        if not self.status_filter.get():
            self.status_filter.current(0)

        # Placeholder visual simple
        if not self.e_search.get():
            self.e_search.insert(0, "")
        self.e_search.config()

        headers = [ld["t_ser"], ld["t_mod"], ld["t_tst"], ld["t_res"], ld["t_dt"], ld["t_usr"]]
        columns = ("serial", "model", "test", "result", "datetime", "user")
        widths = [145, 130, 120, 90, 155, 130]

        for col, name, width in zip(columns, headers, widths):
            self.tree.heading(col, text=name, anchor="w")
            self.tree.column(col, width=width, minwidth=80, stretch=True, anchor="w")

    def apply_theme(self, init=False):
        theme = self.themes["dark" if self.dark_mode else "light"]

        # General backgrounds
        for frame in [
            self.root,
            self.app,
            self.header,
            self.title_block,
            self.header_actions,
            self.main,
            self.kpi_frame
        ]:
            frame.config(bg=theme["app_bg"])

        # Cards
        for card in [
            self.sidebar,
            self.filter_card,
            self.table_card,
            self.chart_card
        ]:
            card.config(
                bg=theme["card"],
                highlightbackground=theme["border"],
                highlightthickness=1
            )

        self.sidebar_section_dates.config(bg=theme["card"])
        self.sidebar_divider.config(bg=theme["border"])
        self.table_inner.config(bg=theme["card"])
        self.chart_frame.config(bg=theme["card"])

        # Labels
        labels = [
            self.lbl_title,
            self.lbl_subtitle,
            self.lbl_controls,
            self.lbl_date_range,
            self.l_start,
            self.l_end,
            self.lbl_table_title,
            self.lbl_chart_title
        ]

        for lbl in labels:
            parent_bg = theme["app_bg"] if lbl in [self.lbl_title, self.lbl_subtitle] else theme["card"]
            lbl.config(bg=parent_bg, fg=theme["text"])

        self.lbl_subtitle.config(fg=theme["text_muted"])
        self.lbl_date_range.config(fg=theme["text_muted"])

        # KPI cards
        for key, item in self.kpi_cards.items():
            item["frame"].config(
                bg=theme["card"],
                highlightbackground=theme["border"],
                highlightthickness=1
            )
            item["label"].config(bg=theme["card"], fg=theme["text_muted"])
            item["value"].config(bg=theme["card"], fg=theme["text"])
            item["hint"].config(bg=theme["card"], fg=theme["text_muted"])

        self.kpi_cards["pass"]["value"].config(fg=theme["success"])
        self.kpi_cards["fail"]["value"].config(fg=theme["danger"])
        self.kpi_cards["yield"]["value"].config(fg=theme["accent"])

        # Buttons
        self.b_lang.config(bg=theme["surface_2"], fg=theme["text"], activebackground=theme["card_hover"])
        self.b_theme.config(bg=theme["surface_2"], fg=theme["text"], activebackground=theme["card_hover"])

        self.btn_scan.config(
            bg=theme["accent"],
            fg="#FFFFFF",
            activebackground=theme["accent_2"],
            activeforeground="#FFFFFF"
        )

        live_bg = theme["success"] if self.live_mode else theme["surface_2"]
        live_fg = "#FFFFFF" if self.live_mode else theme["text"]

        self.btn_live.config(
            bg=live_bg,
            fg=live_fg,
            activebackground=theme["card_hover"],
            activeforeground=live_fg
        )

        for btn in [self.btn_clear_db, self.btn_del]:
            btn.config(
                bg=theme["surface_2"],
                fg=theme["danger"],
                activebackground=theme["card_hover"],
                activeforeground=theme["danger"]
            )

        for btn in [self.btn_excel, self.btn_pdf]:
            btn.config(
                bg=theme["surface_2"],
                fg=theme["text"],
                activebackground=theme["card_hover"],
                activeforeground=theme["text"]
            )

        # Entry
        self.e_search.config(
            bg=theme["entry"],
            fg=theme["text"],
            insertbackground=theme["text"],
            highlightbackground=theme["border"],
            highlightcolor=theme["accent"],
            relief="flat"
        )

        # DateEntry
        try:
            self.e_start.config(
                background=theme["accent"],
                foreground="#FFFFFF",
                selectbackground=theme["accent"],
                selectforeground="#FFFFFF"
            )
            self.e_end.config(
                background=theme["accent"],
                foreground="#FFFFFF",
                selectbackground=theme["accent"],
                selectforeground="#FFFFFF"
            )
        except Exception:
            pass

        # ttk / Treeview
        self.style.configure(
            "Treeview",
            background=theme["card"],
            fieldbackground=theme["card"],
            foreground=theme["text"],
            borderwidth=0,
            rowheight=30,
            font=("Segoe UI", 9)
        )

        self.style.configure(
            "Treeview.Heading",
            background=theme["surface_2"],
            foreground=theme["text"],
            relief="flat",
            font=("Segoe UI", 9, "bold")
        )

        self.style.map(
            "Treeview",
            background=[("selected", theme["selected"])],
            foreground=[("selected", "#FFFFFF")]
        )

        self.style.configure(
            "TCombobox",
            fieldbackground=theme["entry"],
            background=theme["entry"],
            foreground=theme["text"],
            arrowcolor=theme["text"],
            borderwidth=0
        )

        self.style.configure(
            "Horizontal.TProgressbar",
            troughcolor=theme["surface_2"],
            background=theme["accent"],
            bordercolor=theme["surface_2"],
            lightcolor=theme["accent"],
            darkcolor=theme["accent"]
        )

        if not init:
            self.update_dashboard(
                sum(1 for r in self.records if r[4] == "Pass"),
                sum(1 for r in self.records if r[4] == "Fail")
            )
