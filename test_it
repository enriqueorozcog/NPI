    def create_kpi_card(self, key, col):
        card = tk.Frame(self.kpi_frame, height=96)
        card.grid(row=0, column=col, sticky="ew", padx=(0 if col == 0 else 8, 0 if col == 3 else 8))
        card.grid_propagate(False)

        label = tk.Label(card, font=("Segoe UI", 9, "bold"), anchor="w")
        label.pack(fill="x", padx=16, pady=(14, 0))

        value = tk.Label(card, font=("Segoe UI Variable Display", 24, "bold"), anchor="w")
        value.pack(fill="x", padx=16, pady=(4, 0))

        hint = tk.Label(card, font=("Segoe UI", 8), anchor="w")
        hint.pack(fill="x", padx=16, pady=(0, 8))

        self.kpi_cards[key] = {
            "frame": card,
            "label": label,
            "value": value,
            "hint": hint
        }

