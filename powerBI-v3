    def init_database(self):
        self.conn = sqlite3.connect("npi_automated_quality.db")
        self.cursor = self.conn.cursor()
        self.cursor.execute("""
            CREATE TABLE IF NOT EXISTS server_logs (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                serial TEXT NOT NULL, model TEXT NOT NULL,
                test TEXT NOT NULL, result TEXT NOT NULL,
                datetime TEXT NOT NULL, user TEXT NOT NULL,
                UNIQUE(serial, datetime)
            )
        """)
        self.conn.commit()


    def load_data(self, query=""):
        for item in self.tree.get_children(): self.tree.delete(item)
        if query:
            sf = f"%{query}%"
            self.cursor.execute("SELECT id, serial, model, test, result, datetime, user FROM server_logs WHERE serial LIKE ? OR model LIKE ? ORDER BY datetime DESC", (sf, sf))
        else:
            self.cursor.execute("SELECT id, serial, model, test, result, datetime, user FROM server_logs ORDER BY datetime DESC")
            
        self.records = self.cursor.fetchall()
        theme_name = "dark" if self.dark_mode else "light"
        self.tree.tag_configure("pass_row", background=self.themes[theme_name]["pass_bg"])
        self.tree.tag_configure("fail_row", background=self.themes[theme_name]["fail_bg"])
        
        pass_c = sum(1 for r in self.records if r[4] == "Pass")
        fail_c = sum(1 for r in self.records if r[4] == "Fail")
        yield_p = round((pass_c / len(self.records)) * 100, 1) if self.records else 100.0
        
        for row in self.records:
            tag = "pass_row" if row[4] == "Pass" else "fail_row"
            self.tree.insert("", "end", iid=str(row), values=row[1:], tags=(tag,))
            
        self.lbl_status.config(text=self.lang_dict[self.current_lang]["status_total"].format(len(self.records), yield_p))
        self.update_dashboard(pass_c, fail_c)

    def update_dashboard(self, pass_c, fail_c):
        if self.canvas_plot: self.canvas_plot.get_tk_widget().destroy()
        theme = self.themes["dark" if self.dark_mode else "light"]
        fig = Figure(figsize=(6, 1.8), dpi=100, facecolor=theme["card"])
        ax = fig.add_subplot(111, facecolor=theme["card"])
        
        cats = ['Pass', 'Fail'] if self.current_lang == "ENG" else ['Aprobados', 'Fallidos']
        bars = ax.barh(cats, [pass_c, fail_c], color=['#34C759', '#FF3B30'], height=0.55)
        for s in ['top', 'right']: ax.spines[s].set_visible(False)
        ax.spines['left'].set_color(theme["text_sub"])
        ax.spines['bottom'].set_color(theme["text_sub"])
        ax.tick_params(colors=theme["text"], labelsize=9)
        
        for bar in bars:
            w = bar.get_width()
            ax.text(w + 0.1, bar.get_y() + bar.get_height()/2, f'{int(w)}', va='center', ha='left', color=theme["text"], fontsize=9, fontweight='bold')
            
        fig.tight_layout()
        self.canvas_plot = FigureCanvasTkAgg(fig, master=self.chart_frame)
        self.canvas_plot.draw()
        self.canvas_plot.get_tk_widget().pack(fill="both", expand=True)

    def start_async_scan(self):
        self.btn_scan.config(state="disabled")
        threading.Thread(target=self.scan_server_logs, daemon=True).start()

    def scan_server_logs(self):
        try:
            start_d = datetime.datetime.strptime(self.e_start.get().strip(), "%Y-%m-%d").date()
            end_d = datetime.datetime.strptime(self.e_end.get().strip(), "%Y-%m-%d").date()
        except ValueError:
            self.root.after(0, lambda: messagebox.showerror("Error", "Format: YYYY-MM-DD"))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return
            
        if not os.path.exists(self.log_directory):
            self.root.after(0, lambda: messagebox.showerror("Error", f"Path error: {self.log_directory}"))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return
            
        files = glob.glob(os.path.join(self.log_directory, "*.txt")) + glob.glob(os.path.join(self.log_directory, "*.log"))
        valid_files = []
        
        for f in files:
            try:
                f_date = datetime.datetime.fromtimestamp(os.path.getmtime(f)).date()
                if start_d <= f_date <= end_d: valid_files.append(f)
            except Exception: continue
            
        total = len(valid_files)
        if total == 0:
            self.root.after(0, lambda: messagebox.showinfo("Scanner", "0 logs found."))
            self.root.after(0, lambda: self.btn_scan.config(state="normal"))
            return
            
        imported = 0
        for i, f_path in enumerate(valid_files):
            serial, model, test, result, dt = LogParserEngine.parse_file(f_path)
            if serial and dt:
                try:
                    self.cursor.execute("INSERT INTO server_logs (serial, model, test, result, datetime, user) VALUES (?, ?, ?, ?, ?, ?)", (serial, model, test, result, dt, getpass.getuser()))
                    imported += 1
                except sqlite3.IntegrityError: pass
            
            prod = int(((i + 1) / total) * 100)
            self.root.after(0, lambda p=prod: self.progress.configure(value=p))
            
        self.conn.commit()
        self.root.after(0, self.load_data)
        self.root.after(0, lambda: self.progress.configure(value=0))
        self.root.after(0, lambda: self.btn_scan.config(state="normal"))
        self.root.after(0, lambda: messagebox.showinfo("Scanner", f"Scan Done. Added: {imported}"))

    def toggle_live_mode(self):
        self.live_mode = not self.live_mode
        lbl = ("📡 Modo En Vivo: ON" if self.live_mode else "📡 Modo En Vivo: OFF") if self.current_lang == "ESP" else ("📡 Live Mode: ON" if self.live_mode else "📡 Live Mode: OFF")
        self.btn_live.config(text=lbl, bg="#34C759" if self.live_mode else self.themes["dark" if self.dark_mode else "light"]["card"])

    def run_live_loop(self):
        if self.live_mode:
            threading.Thread(target=self.scan_server_logs, daemon=True).start()
        self.root.after(5000, self.run_live_loop)

    def delete_item(self):
        sel = self.tree.selection()
        if not sel: return
        self.cursor.execute("DELETE FROM server_logs WHERE id = ?", (eval(sel)[0],))
        self.conn.commit()
        self.load_data()

    def clear_database(self):
        if messagebox.askyesno(self.lang_dict[self.current_lang]["clear_title"], self.lang_dict[self.current_lang]["clear_msg"]):
            self.cursor.execute("DELETE FROM server_logs")
            self.conn.commit()
            self.load_data()

