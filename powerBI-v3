class LogParserEngine:
    """Motor de análisis estructural para logs en red."""
    @staticmethod
    def parse_file(file_path):
        serial, model, test = None, None, None
        result, dt = "Fail", None
        
        ts_re = re.compile(r"^\[(?P<dt>\d{4}-\d{2}-\d{2})T(?P<t>\d{2}:\d{2}:\d{2})")
        js_re = re.compile(r"-\s+(\{.*ProductName.*SerialNumber.*\})")
        
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                f.seek(0)
                for line in f:
                    if not dt:
                        ts_m = ts_re.match(line)
                        if ts_m:
                            dt = f"{ts_m.group('dt')} {ts_m.group('t')}"
                    
                    if "Starting CrewReprovision..." in line:
                        test = "Provision"
                    elif "Starting CrewDevicePrep..." in line:
                        test = "DevicePrep"
                    
                    js_m = js_re.search(line)
                    if js_m:
                        try:
                            d = json.loads(js_m.group(1))
                            serial = d.get("SerialNumber") or d.get("SystemDutSn")
                            model = d.get("ProductName") or d.get("Project")
                        except Exception:
                            pass

            if "Crew-DevicePrep Success" in content or "Crew-Reprovision Success" in content:
                result = "Pass"
            else:
                result = "Fail"
                
        except Exception as e:
            print(f"Error analizando {file_path}: {e}")
            
        return serial, model, test, result, dt

